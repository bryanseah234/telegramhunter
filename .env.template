     4|
     5|# General Configuration
     6|ENV=development
     7|DEBUG=False
     8|
     9|# Redis (Docker internal network)
    10|REDIS_URL=redis://redis:6379/0
    11|
    12|# Encryption Key (Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
    13|ENCRYPTION_KEY=your-44-char-fernet-key-here
    14|
    15|# Optional: Protect monitor endpoints (/monitor/*) with this API key (sent as X-Monitor-Key)
    16|MONITOR_API_KEY=
    17|
    18|# Extension (Chrome): Enter your Supabase URL and anon key directly in the extension popup.
    19|# Credentials are stored in chrome.storage.sync — never committed to source control.
    20|# Generate a strong random secret and set it in BOTH places:
    21|#   1. Here (so you can copy it into the extension popup)
    22|#   2. In Supabase SQL Editor: ALTER DATABASE postgres SET app.extension_write_secret = '<value>';
    23|# Retrieve from Supabase anytime: SELECT current_setting('app.extension_write_secret');
    24|EXTENSION_WRITE_SECRET=
    25|
    26|# ============================================
    27|# Supabase Database
    28|# ============================================
    29|SUPABASE_URL=https://your-project.supabase.co
    30|SUPABASE_KEY=your-anon-key
    31|SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
    32|
    33|# GitHub Actions Secrets (for keepalive workflow to prevent auto-pause)
    34|# Set these in GitHub Repository Settings → Secrets and variables → Actions:
    35|# - NEXT_PUBLIC_SUPABASE_URL = your Supabase project URL (same as SUPABASE_URL)
    36|# - NEXT_PUBLIC_SUPABASE_KEY = your Supabase anon key (same as SUPABASE_KEY)
    37|# These keys allow GitHub Actions to ping the database every 3 days to prevent 7-day auto-pause.
    38|
